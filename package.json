{
    "name": "nuit-bot",
    "module": "src/main.ts",
    "type": "module",
    "private": true,
    "devDependencies": {
        "@types/bun": "^1.3.13",
        "@types/express": "^5.0.6",
        "@types/pg": "^8.20.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.2",
        "drizzle-kit": "^0.31.10",
        "vite": "^8.0.13"
    },
    "peerDependencies": {
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@nuit-bot/api": "^0.0.22",
        "@phosphor-icons/react": "^2.1.10",
        "better-auth": "^1.6.10",
        "chalk": "^5.6.2",
        "discord-api-types": "^0.38.47",
        "discord.js": "^14.26.3",
        "drizzle-orm": "^0.45.2",
        "express": "^5.2.1",
        "helmet": "^8.1.0",
        "pg": "^8.20.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-router-dom": "^7.15.1",
        "toml": "^4.1.1"
    },
    "scripts": {
        "dev": "bun --watch .",
        "start": "bun run src/main.ts",
        "dev:web": "bun --bun ./node_modules/vite/bin/vite.js",
        "dev:bot": "bun run src/index.ts",
        "build:web": "bun --bun ./node_modules/vite/bin/vite.js build",
        "build": "bun run build:web && bun build src/index.ts --outdir dist"
    }
}
